rules_version = '2';

// ===============================================================
// Firestore Security Rules
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Check if the user is authenticated
    function isAuthenticated() {
       return request.auth != null;
    }

    // Check if the authenticated user has the 'admin' role in their user profile doc
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Default deny for all documents
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for the products collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for the users collection
    match /users/{uid} {
      allow read: if true;
      // Allow users to write their own profile document on register
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Rules for the categories collection
    match /categories/{categoryId} {
      allow read: if true;
      // Only admins can add, update, or delete categories
      allow write: if isAdmin();
    }

    // Rules for the brands collection
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
